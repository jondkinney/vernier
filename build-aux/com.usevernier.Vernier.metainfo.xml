<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.usevernier.Vernier</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT OR Apache-2.0</project_license>
  <name>Vernier</name>
  <summary>Native pixel-measurement screen overlay</summary>
  <icon type="stock">com.usevernier.Vernier</icon>
  <launchable type="desktop-id">com.usevernier.Vernier.desktop</launchable>
  <description>
    <p>
      Vernier is a native pixel-measurement overlay for designers and developers.
      Edge-detected snaps lock to real element bounds, with sticky guides, pinned
      measurements, and region capture for one-click hand-off to your annotation tool.
    </p>
    <p>
      Press Enter on a measurement to copy the value to the system clipboard.
      Works on macOS, Linux (Wayland), and Windows.
    </p>
  </description>
  <screenshots>
    <screenshot type="default">
      <caption>Measuring a 320×160 px region with edge-detected snaps locked to the element bounds</caption>
      <image>https://usevernier.com/assets/screenshot-overlay.png</image>
    </screenshot>
  </screenshots>
  <categories>
    <category>Utility</category>
    <category>Graphics</category>
  </categories>
  <!-- OARS: every age-rating attribute defaults to "none", which is
       correct for a measurement overlay. Self-closing element is the
       standard Flathub shorthand for an all-clean rating. -->
  <content_rating type="oars-1.1"/>
  <!-- Per-release entries: prepend a new <release> at the top when
       release-plz cuts a new tag. Required by Flathub for the
       Version history section on the listing page; the latest
       release is the only one strictly required. -->
  <releases>
    <release version="0.2.6" date="2026-05-19"/>
  </releases>
  <url type="homepage">https://usevernier.com</url>
  <url type="bugtracker">https://github.com/jondkinney/vernier/issues</url>
  <developer_name>Jon Kinney</developer_name>
</component>
